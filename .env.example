APP_NAME="Marketplace Listing Export"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Optional override for Meta's bulk upload CSV header template (defaults to storage/Facebook Bulk Upload Template.csv)
# FACEBOOK_BULK_UPLOAD_TEMPLATE_PATH=

EXPORT_LINK_TTL_DAYS=7

# OpenAI Responses API — web_search for listing URLs + optional photo URL discovery (requires OPENAI_API_KEY)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_LISTING_INDEX_MODEL=gpt-5
# OPENAI_LISTING_INDEX_REASONING_EFFORT=medium
# OPENAI_LISTING_INDEX_ENABLED=true
# Legacy alias for OPENAI_LISTING_INDEX_ENABLED:
# OPENAI_LISTING_INDEX_FALLBACK_ENABLED=true
# OPENAI_LISTING_DETAIL_IMAGES_MODEL=gpt-5
# OPENAI_LISTING_DETAIL_IMAGES_REASONING_EFFORT=medium
# OPENAI_LISTING_DETAIL_IMAGES_ENABLED=true
# OPENAI_MAX_TOOL_ROUNDS=8

# HTTP_USER_AGENT=
# SCRAPER_TIMEOUT_SECONDS=
# MAX_LISTINGS_PER_JOB=
# MAX_TOTAL_IMAGE_BYTES=
# MAX_IMAGES_PER_LISTING=5
# IMAGE_DOWNLOAD_CONCURRENCY=8
# EXPORT_CREATE_RATE_PER_MINUTE=
# EXPORT_DOWNLOAD_RATE_PER_MINUTE=
# EXPORT_PURGE_BUFFER_HOURS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
